# ===== Orbit Remote server stack (.env) =====
# Used by both the signaling server and docker-compose (signaling + coturn).

# --- Signaling server ---
PORT=8080
HOST=0.0.0.0
NODE_ENV=production
HEARTBEAT_INTERVAL_MS=30000

# --- Public address of your VPS (required for TURN) ---
EXTERNAL_IP=203.0.113.10

# --- TURN / coturn credentials (must match on both sides) ---
TURN_REALM=orbit.example.com
TURN_USERNAME=orbit
TURN_PASSWORD=change_me_to_a_strong_secret

# --- ICE advertised to clients ---
# When deploying with docker-compose these are derived from EXTERNAL_IP, but you
# can override STUN/TURN explicitly here if you front coturn with a DNS name.
STUN_URLS=stun:stun.l.google.com:19302,stun:stun1.l.google.com:19302
TURN_URLS=
# TURN_USERNAME / TURN_PASSWORD above are reused for the advertised TURN server.
